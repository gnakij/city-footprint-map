# City Footprint Map — 环境变量
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env

# JWT 签名密钥（必须！随机生成: python3 -c "import secrets;print(secrets.token_hex(32))"）
CITYPRINT_SECRET_KEY=

# 数据库路径（可选，默认 backend/data/cityprint.db）
# CITYPRINT_DB_PATH=backend/data/cityprint.db

# 首个管理员初始化（可选）
# 留空时，空库启动不会自动创建固定账号；前端会显示首次管理员设置页。
# 若需要部署时自动初始化，用户名和密码必须同时设置。
# CITYPRINT_ADMIN_USERNAME=admin
# CITYPRINT_ADMIN_PASSWORD=replace-with-a-strong-password
# CITYPRINT_ADMIN_NAME=管理员
